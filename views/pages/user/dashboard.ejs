<section class="section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Dashboard</h2>
      <p class="section-subtitle">Welcome back, Alex. Here is your inventory activity overview.</p>
    </div>
    <div class="inline-actions">
      <a href="/parts-list" class="btn btn-primary">Browse Parts</a>
      <a href="/checkouts/create" class="btn btn-secondary">New Checkout</a>
    </div>
  </div>
</section>

<section class="section stats-grid">
  <article class="stat-card">
    <p class="stat-label">Total Parts</p>
    <p class="stat-value">248</p>
  </article>

  <article class="stat-card">
    <p class="stat-label">Active Checkouts</p>
    <p class="stat-value">19</p>
  </article>

  <article class="stat-card">
    <p class="stat-label">Low Stock Items</p>
    <p class="stat-value">12</p>
  </article>

  <article class="stat-card">
    <p class="stat-label">Transactions This Week</p>
    <p class="stat-value">63</p>
  </article>
</section>

<section class="section cards-grid two-col">
  <article class="card">
    <h3 class="card-title">Recent Activity</h3>
    <p class="card-text">3 torque sensors were checked out this morning.</p>
    <p class="card-text">Inventory count was updated for fasteners in Aisle B.</p>
    <p class="card-text">A low-stock alert was triggered for relay modules.</p>
  </article>

  <article class="card">
    <h3 class="card-title">System Notice</h3>
    <div class="alert alert-warning">
      Some item quantities are running low and should be reviewed soon.
    </div>
    <span class="badge badge-yellow">Attention Needed</span>
  </article>
</section>
