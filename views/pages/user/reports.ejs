<section class="section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Reports</h2>
      <p class="section-subtitle">
        Review inventory trends, checkout activity, and stock condition using realistic dummy data.
      </p>
    </div>
    <div class="inline-actions">
      <a href="#" class="btn btn-outline">Filter Date Range</a>
      <a href="#" class="btn btn-primary">Export Report</a>
    </div>
  </div>
</section>

<section class="section kpi-strip">
  <article class="stat-card">
    <p class="stat-label">Monthly Checkouts</p>
    <p class="stat-value">84</p>
  </article>

  <article class="stat-card">
    <p class="stat-label">Returned On Time</p>
    <p class="stat-value">76%</p>
  </article>

  <article class="stat-card">
    <p class="stat-label">Low Stock Alerts</p>
    <p class="stat-value">12</p>
  </article>
</section>

<section class="section cards-grid two-col">
  <article class="card">
    <h3 class="card-title">Checkout Activity Overview</h3>
    <div class="chart-placeholder" aria-label="Checkout activity chart placeholder">
      <p class="card-text">Weekly checkout volume</p>

      <div class="chart-bars">
        <div class="chart-bar-row">
          <span>Mon</span>
          <div class="chart-bar"><div class="chart-bar-fill bar-62"></div></div>
          <span>18</span>
        </div>
        <div class="chart-bar-row">
          <span>Tue</span>
          <div class="chart-bar"><div class="chart-bar-fill bar-78"></div></div>
          <span>24</span>
        </div>
        <div class="chart-bar-row">
          <span>Wed</span>
          <div class="chart-bar"><div class="chart-bar-fill bar-55"></div></div>
          <span>16</span>
        </div>
        <div class="chart-bar-row">
          <span>Thu</span>
          <div class="chart-bar"><div class="chart-bar-fill bar-84"></div></div>
          <span>26</span>
        </div>
        <div class="chart-bar-row">
          <span>Fri</span>
          <div class="chart-bar"><div class="chart-bar-fill bar-48"></div></div>
          <span>14</span>
        </div>
      </div>
    </div>
  </article>

  <article class="card">
    <h3 class="card-title">Reporting Notes</h3>
    <p class="card-text">Electrical and sensor categories continue to account for the highest usage.</p>
    <p class="card-text">Overdue returns decreased compared to the previous reporting period.</p>
    <p class="card-text">Low-stock alerts remain concentrated in frequently used maintenance items.</p>
    <div class="alert alert-warning">
      Some report values indicate areas where inventory review should be prioritized.
    </div>
  </article>
</section>

<section class="section">
  <article class="card">
    <h3 class="card-title">Category Usage Summary</h3>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Total Parts</th>
            <th>Monthly Checkouts</th>
            <th>Low Stock Items</th>
            <th>Trend</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Electrical</td>
            <td>72</td>
            <td>31</td>
            <td>4</td>
            <td><span class="badge badge-blue">High Use</span></td>
          </tr>
          <tr>
            <td>Sensors</td>
            <td>34</td>
            <td>19</td>
            <td>3</td>
            <td><span class="badge badge-yellow">Watch</span></td>
          </tr>
          <tr>
            <td>Hardware</td>
            <td>58</td>
            <td>14</td>
            <td>2</td>
            <td><span class="badge badge-green">Stable</span></td>
          </tr>
          <tr>
            <td>Pneumatics</td>
            <td>26</td>
            <td>11</td>
            <td>1</td>
            <td><span class="badge badge-green">Stable</span></td>
          </tr>
          <tr>
            <td>Tools</td>
            <td>18</td>
            <td>9</td>
            <td>0</td>
            <td><span class="badge badge-green">Stable</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>
</section>

<section class="section cards-grid two-col">
  <article class="card">
    <h3 class="card-title">Most Checked Out Parts</h3>
    <p class="card-text">1. Relay Module RM-24</p>
    <p class="card-text">2. Torque Sensor TS-9</p>
    <p class="card-text">3. Fuse Pack FP-20</p>
    <p class="card-text">4. Air Regulator AR-5</p>
  </article>

  <article class="card">
    <h3 class="card-title">Report Context</h3>
    <div class="alert alert-success">
      These report sections are hardcoded and designed to demonstrate frontend layout, hierarchy, and responsive styling.
    </div>
    <p class="card-text">
      In a later sprint, these values can be replaced by database-driven reporting data.
    </p>
  </article>
</section>
